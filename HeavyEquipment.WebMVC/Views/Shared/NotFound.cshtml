@{
    ViewData["Title"] = "الصفحة غير موجودة";
    Layout = "_NewLayout";
}

<div style="min-height:70vh;display:flex;align-items:center;justify-content:center;padding:2rem">
    <div style="text-align:center;max-width:500px">

        <div style="font-family:var(--font-en);font-size:8rem;color:var(--gold);
                    line-height:1;opacity:0.3;margin-bottom:1rem">
            404
        </div>

        <div style="width:60px;height:3px;background:var(--gold);margin:0 auto 1.5rem"></div>

        <h1 style="font-family:var(--font-en);font-size:2rem;letter-spacing:2px;margin-bottom:1rem">
            PAGE NOT FOUND
        </h1>

        <p style="color:var(--muted);font-size:0.95rem;line-height:1.8;margin-bottom:2rem">
            الصفحة التي تبحث عنها غير موجودة أو تم نقلها.
            تأكد من الرابط أو ارجع للصفحة الرئيسية.
        </p>

        <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap">
            <a href="/" class="btn-primary">🏠 الرئيسية</a>
            <a asp-controller="Equipment" asp-action="Index" class="btn-outline">
                🔍 تصفح المعدات
            </a>
        </div>

    </div>
</div>
