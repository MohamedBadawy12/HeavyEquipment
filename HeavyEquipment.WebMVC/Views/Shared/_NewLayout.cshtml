<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — HeavyHub</title>

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;600;700;900&family=Bebas+Neue&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" />

    <style>
        .nav-link-btn {
            display: block;
            width: 100%;
            padding: 0.7rem 1.2rem;
            background: none;
            border: none;
            color: var(--muted);
            font-family: var(--font-ar);
            font-size: 0.875rem;
            text-align: right;
            cursor: pointer;
            transition: background 0.2s, color 0.2s;
        }

            .nav-link-btn.danger {
                color: #c0392b;
            }

                .nav-link-btn.danger:hover {
                    background: rgba(192,57,43,0.1);
                    color: #e74c3c;
                }

        .nav-links.mobile-open {
            display: flex;
            flex-direction: column;
            position: fixed;
            top: 70px;
            left: 0;
            right: 0;
            background: rgba(10,10,10,0.98);
            border-bottom: 1px solid var(--border);
            padding: 1.5rem 2rem;
            gap: 1rem;
            z-index: 99;
        }

            .nav-links.mobile-open li {
                width: 100%;
            }

            .nav-links.mobile-open a {
                font-size: 1rem;
                padding: 0.5rem 0;
            }
    </style>
    @if (IsSectionDefined("Styles"))
    {
        @await RenderSectionAsync("Styles", required: false)
    }
    @if (ViewData["PageCss"] != null)
    {
        <link rel="stylesheet" href="~/css/@(ViewData["PageCss"]).css" />
    }
</head>
<body>

    <!-- ===== NAVBAR ===== -->
    <nav class="navbar" id="navbar">

        <!-- Logo -->
        <a href="/" class="nav-logo">
            <div class="logo-icon">⚙</div>
            <span class="logo-text">HEAVY<span>HUB</span></span>
        </a>

        <!-- Links -->
        <ul class="nav-links">
            <li><a asp-controller="Home" asp-action="Index">الرئيسية</a></li>
            <li><a asp-controller="Equipment" asp-action="Index">تصفح المعدات</a></li>
            <li><a asp-controller="Home" asp-action="HowItWorks">كيف يعمل</a></li>
            <li><a asp-controller="Home" asp-action="About">عن المنصة</a></li>

            @if (User.Identity!.IsAuthenticated)
            {
                <!-- User Dropdown -->
                <li class="nav-user">
                    <button class="nav-user-btn">
                        <div class="nav-avatar">
                            @User.Identity.Name?[0].ToString().ToUpper()
                        </div>
                        @User.Identity.Name
                        ▾
                    </button>
                    <div class="nav-dropdown">
                        @if (User.IsInRole("Owner")||User.IsInRole("Admin"))
                        {
                            <a asp-controller="Dashboard" asp-action="Index">📊 لوحة التحكم</a>
                            <a asp-controller="Equipment" asp-action="MyEquipments">🏗 معداتي</a>
                        }
                        else
                        {
                            <a asp-controller="RentalOrder" asp-action="MyOrders">📋 طلباتي</a>
                        }
                        <a asp-controller="Account" asp-action="Profile">👤 الملف الشخصي</a>
                        <a asp-controller="Notification" asp-action="Index">🔔 الإشعارات</a>
                        <form asp-controller="Account" asp-action="Logout" method="post" style="margin:0; padding:0">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="nav-link-btn danger">
                                🚪 تسجيل الخروج
                            </button>
                        </form>
                    </div>
                </li>
            }
            else
            {
                <li><a asp-controller="Account" asp-action="Login">تسجيل الدخول</a></li>
                <li><a asp-controller="Account" asp-action="Register" class="nav-cta">ابدأ الآن</a></li>
            }
        </ul>

        <!-- Mobile Menu Button -->
        <button class="nav-mobile-btn" onclick="toggleMobileMenu()">☰</button>
    </nav>

    <!-- ===== MAIN CONTENT ===== -->
    <main class="page-wrapper">

        <!-- TempData Alerts -->
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success" style="margin: 1rem 4rem 0;">
                ✅ @TempData["Success"]
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-error" style="margin: 1rem 4rem 0;">
                ❌ @TempData["Error"]
            </div>
        }

        @if (TempData["Warning"] != null)
        {
            <div class="alert alert-warning" style="margin: 1rem 4rem 0;">
                ⚠️ @TempData["Warning"]
            </div>
        }

        <!-- Page Content -->
        @RenderBody()

    </main>

    <!-- ===== FOOTER ===== -->
    <footer class="footer">
        <div class="footer-grid">
            <div class="footer-brand">
                <a href="/" class="nav-logo">
                    <div class="logo-icon">⚙</div>
                    <span class="logo-text" style="font-size:1.4rem">HEAVY<span>HUB</span></span>
                </a>
                <p>منصة التداول التشاركي للمعدات الثقيلة في مصر والشرق الأوسط. نربط أصحاب المعدات بالمقاولين بأمان وسهولة.</p>
            </div>

            <div>
                <div class="footer-heading">المنصة</div>
                <ul class="footer-links">
                    <li><a asp-controller="Equipment" asp-action="Index">تصفح المعدات</a></li>
                    <li><a asp-controller="Home" asp-action="HowItWorks">كيف يعمل</a></li>
                    <li><a asp-controller="Home" asp-action="About">عن المنصة</a></li>
                    <li><a asp-controller="Home" asp-action="Contact">تواصل معنا</a></li>
                </ul>
            </div>

            <div>
                <div class="footer-heading">الدعم</div>
                <ul class="footer-links">
                    <li><a asp-controller="Home" asp-action="FAQ">الأسئلة الشائعة</a></li>
                    <li><a asp-controller="Home" asp-action="Insurance">التأمين</a></li>
                    <li><a asp-controller="Home" asp-action="Safety">السلامة</a></li>
                </ul>
            </div>

            <div>
                <div class="footer-heading">قانوني</div>
                <ul class="footer-links">
                    <li><a asp-controller="Home" asp-action="Terms">الشروط والأحكام</a></li>
                    <li><a asp-controller="Home" asp-action="Privacy">سياسة الخصوصية</a></li>
                </ul>
            </div>
        </div>

        <div class="footer-bottom">
            <div>© @DateTime.Now.Year HeavyHub. جميع الحقوق محفوظة.</div>
            <div class="footer-social">
                <a href="#">LinkedIn</a>
                <a href="#">Twitter</a>
                <a href="#">Facebook</a>
            </div>
        </div>
    </footer>

    <!-- ===== SCRIPTS ===== -->
    <script src="~/js/site.js"></script>

    @if (IsSectionDefined("Scripts"))
    {
         @await RenderSectionAsync("Scripts", required: false)
    }
    <script>
        window.toggleMobileMenu = function () {
            var navLinks = document.querySelector('.nav-links');
            if (!navLinks) return;
            var isOpen = navLinks.classList.toggle('mobile-open');
            var btn = document.querySelector('.nav-mobile-btn');
            if (btn) btn.textContent = isOpen ? '✕' : '☰';
        };
    </script>
</body>
</html>
