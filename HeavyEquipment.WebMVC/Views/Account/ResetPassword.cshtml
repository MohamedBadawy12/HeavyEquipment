@model HeavyEquipment.Application.Features.Users.Commands.ResetPasswordCommand
@{
    ViewData["Title"] = "تغير كلمة المرور";
    Layout = "_NewLayout";
    ViewData["PageCss"] = "auth";
}
<style>
    .form-control {
        background: var(--card) !important;
        border: 1px solid var(--border) !important;
        color: var(--white) !important;
        padding: 0.8rem 1rem;
        border-radius: 0;
        width: 100%;
        transition: border-color 0.3s;
    }

        .form-control:focus {
            border-color: var(--gold) !important;
            outline: none;
            box-shadow: 0 0 0 2px rgba(212,168,67,0.1);
        }

    .btn-gold {
        background: var(--gold);
        color: var(--black);
        border: none;
        font-weight: 700;
        transition: transform 0.2s, opacity 0.2s;
        cursor: pointer;
    }

        .btn-gold:hover {
            transform: translateY(-2px);
            opacity: 0.9;
        }
</style>
<div class="auth-wrapper">
    <div class="auth-side">
    </div>

    <main class="auth-main">
        <div class="auth-card">
            <div class="auth-card-header">
                <h1 class="auth-title">إعادة تعيين كلمة المرور</h1>
                <p class="auth-subtitle">أدخل الكود المرسل إليك وكلمة المرور الجديدة.</p>
            </div>

            <form asp-action="ResetPassword" method="post">
                <input type="hidden" asp-for="PhoneNumber" value="@TempData["PhoneNumber"]" />

                <div class="form-group mb-3">
                    <label class="form-label">كود التحقق (6 أرقام)</label>
                    <input asp-for="Code" class="form-control" placeholder="000000" maxlength="6" required />
                </div>

                <div class="form-group mb-3">
                    <label class="form-label">كلمة المرور الجديدة</label>
                    <div class="input-password-wrapper">
                        <input asp-for="NewPassword" type="password" class="form-control" id="pass" required />
                        <button type="button" class="toggle-password" onclick="togglePass('pass')">👁️</button>
                    </div>
                </div>

                <button type="submit" class="btn btn-gold btn-full">تحديث كلمة المرور</button>
            </form>
        </div>
    </main>
</div>

<script>
    function togglePass(id) {
        var x = document.getElementById(id);
        x.type = x.type === "password" ? "text" : "password";
    }
</script>