@model HeavyEquipment.Application.Features.Users.Commands.ForgotPasswordCommand
@{
    ViewData["Title"] = "نسيت كلمة المرور";
    Layout = "_NewLayout";
    ViewData["PageCss"] = "auth";
}
<style>
    .form-control {
        background: var(--card) !important;
        border: 1px solid var(--border) !important;
        color: var(--white) !important;
        padding: 0.8rem 1rem;
        border-radius: 0; 
        width: 100%;
        transition: border-color 0.3s;
    }

        .form-control:focus {
            border-color: var(--gold) !important;
            outline: none;
            box-shadow: 0 0 0 2px rgba(212,168,67,0.1);
        }

    .btn-gold {
        background: var(--gold);
        color: var(--black);
        border: none;
        font-weight: 700;
        transition: transform 0.2s, opacity 0.2s;
        cursor: pointer;
    }

        .btn-gold:hover {
            transform: translateY(-2px);
            opacity: 0.9;
        }
</style>
<div class="auth-wrapper">
    <div class="auth-side">
        <div class="auth-side-content">
            <a href="/" class="auth-logo">
                <span style="color:var(--gold); font-size: 1.5rem;">🏗️</span>
                <span class="auth-side-title" style="margin-bottom:0">HEAVY EQUIP</span>
            </a>
            <h2 class="auth-side-title">استعادة الوصول إلى حسابك</h2>
            <p class="auth-side-desc">أدخل رقم هاتفك المسجل وسنقوم بإرسال كود التحقق عبر رسالة نصية SMS.</p>

            <div class="auth-features">
                <div class="auth-feature">
                    <div class="auth-feature-icon">🔒</div>
                    <div>
                        <div class="auth-feature-title">أمان عالي</div>
                        <div class="auth-feature-desc">تشفير كامل لبياناتك الشخصية.</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <main class="auth-main">
        <div class="auth-card">
            <div class="auth-card-header">
                <h1 class="auth-title">نسيت كلمة المرور؟</h1>
                <p class="auth-subtitle">لا تقلق، سنساعدك في استعادتها.</p>
            </div>

            <form asp-action="ForgotPassword" method="post">
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger" style="background: rgba(220, 53, 69, 0.1); border: 1px solid #dc3545; color: #dc3545; padding: 1rem; margin-bottom: 1.5rem; font-size: 0.85rem;">
                        <div asp-validation-summary="All"></div>
                    </div>
                }

                <div class="form-group mb-4">
                    <label class="form-label" style="color: var(--muted); font-size: 0.85rem; margin-bottom: 0.5rem; display: block;">رقم الهاتف</label>
                    <div class="input-password-wrapper">
                        <input asp-for="PhoneNumber" class="form-control" placeholder="+201xxxxxxxxx" required />
                        <span class="toggle-password" style="left: auto; right: 0.8rem;">📱</span>
                    </div>
                    <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn btn-gold btn-full">إرسال كود التحقق</button>

                <div class="auth-footer">
                    تذكرت كلمة المرور؟ <a asp-action="Login">تسجيل الدخول</a>
                </div>
            </form>
        </div>
    </main>
</div>