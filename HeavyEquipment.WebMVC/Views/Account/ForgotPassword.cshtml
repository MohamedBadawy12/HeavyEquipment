
@{
    ViewData["Title"] = "نسيت كلمة المرور";
    Layout = "_NewLayout";
    ViewData["PageCss"] = "auth";
}
<style>
    .form-control {
        background: var(--card) !important;
        border: 1px solid var(--border) !important;
        color: var(--white) !important;
        padding: 0.8rem 1rem;
        border-radius: 0; 
        width: 100%;
        transition: border-color 0.3s;
    }

        .form-control:focus {
            border-color: var(--gold) !important;
            outline: none;
            box-shadow: 0 0 0 2px rgba(212,168,67,0.1);
        }

    .btn-gold {
        background: var(--gold);
        color: var(--black);
        border: none;
        font-weight: 700;
        transition: transform 0.2s, opacity 0.2s;
        cursor: pointer;
    }

        .btn-gold:hover {
            transform: translateY(-2px);
            opacity: 0.9;
        }
</style>
<div class="auth-wrapper">
    <div class="auth-side">
        <div class="auth-side-content">
            <a href="/" class="auth-logo">
                <span style="color:var(--gold); font-size: 1.5rem;">🏗️</span>
                <span class="auth-side-title" style="margin-bottom:0">HEAVY EQUIP</span>
            </a>
            <h2 class="auth-side-title">استعادة الوصول إلى حسابك</h2>
            <p class="auth-side-desc">أدخل رقم هاتفك المسجل وسنقوم بإرسال كود التحقق عبر رسالة نصية SMS.</p>

            <div class="auth-features">
                <div class="auth-feature">
                    <div class="auth-feature-icon">🔒</div>
                    <div>
                        <div class="auth-feature-title">أمان عالي</div>
                        <div class="auth-feature-desc">تشفير كامل لبياناتك الشخصية.</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <main class="auth-main">
        <div class="auth-card">
            <div class="auth-card-header">
                <h1 class="auth-title">نسيت كلمة المرور؟</h1>
                <p class="auth-subtitle">لا تقلق، سنساعدك في استعادتها.</p>
            </div>

            @if (TempData["Info"] != null)
            {
                <div class="alert alert-warning">ℹ️ @TempData["Info"]</div>
            }

            <form asp-action="ForgotPassword" method="post">
                @Html.AntiForgeryToken()

                <div class="form-group">
                    <label class="form-label">رقم الهاتف *</label>
                    <input type="tel" name="phoneNumber" class="form-control"
                           placeholder="مثال: 01012345678" required />
                    <small style="color:var(--muted);font-size:0.78rem;margin-top:0.3rem;display:block">
                        الرقم المسجل في حسابك
                    </small>
                </div>

                <button type="submit" class="btn-primary btn-full" style="margin-top:0.5rem">
                    📱 إرسال كود التحقق
                </button>
            </form>
            <div style="text-align:center;margin-top:1.5rem;font-size:0.875rem;color:var(--muted)">
                تذكرت كلمة المرور؟
                <a asp-action="Login" style="color:var(--gold);text-decoration:none;font-weight:700">
                    تسجيل الدخول
                </a>
            </div>
        </div>
    </main>
</div>