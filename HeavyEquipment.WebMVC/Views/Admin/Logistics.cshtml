@using HeavyEquipment.Application.Features.Logistics.Dtos
@model IReadOnlyList<LogisticsProviderAdminDto>
@{
    ViewData["Title"] = "إدارة شركات النقل";
    Layout = "_NewLayout";
    ViewData["PageCss"] = "admin";
}

<div class="inner-page">
    <div class="page-header">
        <div class="page-header-content">
            <div class="section-label">ADMIN — LOGISTICS</div>
            <div class="gold-divider"></div>
            <h1 class="section-title">شركات النقل</h1>
            <p class="page-header-desc">إدارة شركات نقل المعدات الثقيلة</p>
        </div>
        <a asp-action="Index" class="btn-outline btn-sm">← لوحة الإدارة</a>
    </div>

    <div class="dashboard-body">

        <!-- Stats -->
        <div class="stats-grid">
            <div class="stat-card stat-gold">
                <div class="stat-icon">🚛</div>
                <div class="stat-content">
                    <div class="stat-value">@Model.Count</div>
                    <div class="stat-label">إجمالي الشركات</div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon">✅</div>
                <div class="stat-content">
                    <div class="stat-value">@Model.Count(p => p.IsActive)</div>
                    <div class="stat-label">نشطة</div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon">🚫</div>
                <div class="stat-content">
                    <div class="stat-value">@Model.Count(p => !p.IsActive)</div>
                    <div class="stat-label">معطلة</div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon">💰</div>
                <div class="stat-content">
                    <div class="stat-value">
                        @(Model.Any() ? Model.Where(p => p.IsActive).Average(p => p.RatePerKilometer).ToString("N1") : "0")
                        <span>ج.م</span>
                    </div>
                    <div class="stat-label">متوسط السعر/كم</div>
                </div>
            </div>
        </div>

        <!-- Add New -->
        <div class="dashboard-card" style="padding:1.5rem">
            <div class="dashboard-card-header" style="padding:0 0 1rem;border-bottom:1px solid var(--border);margin-bottom:1.5rem">
                <div class="dashboard-card-title">➕ إضافة شركة نقل جديدة</div>
            </div>
            <form asp-action="CreateLogistics" method="post">
                @Html.AntiForgeryToken()
                <div class="form-row" style="grid-template-columns:1fr 1fr 1fr auto">
                    <div class="form-group" style="margin:0">
                        <label class="form-label">اسم الشركة *</label>
                        <input type="text" name="companyName" class="form-control"
                               placeholder="مثال: شركة النيل للنقل" required />
                    </div>
                    <div class="form-group" style="margin:0">
                        <label class="form-label">رقم التواصل *</label>
                        <input type="text" name="contactNumber" class="form-control"
                               placeholder="مثال: 01099991111" required />
                    </div>
                    <div class="form-group" style="margin:0">
                        <label class="form-label">السعر / كيلومتر (ج.م) *</label>
                        <input type="number" name="ratePerKilometer" class="form-control"
                               placeholder="مثال: 15" min="1" step="0.5" required />
                    </div>
                    <div class="form-group" style="margin:0;display:flex;align-items:flex-end">
                        <button type="submit" class="btn-primary">إضافة</button>
                    </div>
                </div>
            </form>
        </div>

        <!-- Providers Table -->
        <div class="dashboard-card" style="padding:0">
            @if (!Model.Any())
            {
                <div class="empty-state">
                    <div class="empty-icon">🚛</div>
                    <div class="empty-title">لا توجد شركات نقل</div>
                    <div class="empty-desc">أضف شركة نقل من الأعلى</div>
                </div>
            }
            else
            {
                <div class="admin-table-wrap">
                    <table class="admin-table">
                        <thead>
                            <tr>
                                <th>الشركة</th>
                                <th>رقم التواصل</th>
                                <th>السعر / كم</th>
                                <th>الحالة</th>
                                <th>تحديث السعر</th>
                                <th>إجراءات</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var p in Model)
                            {
                                <tr class="@(!p.IsActive ? "row-blocked" : "")">
                                    <td>
                                        <div style="display:flex;align-items:center;gap:0.8rem">
                                            <span style="font-size:1.4rem">🚛</span>
                                            <div class="admin-user-name">@p.CompanyName</div>
                                        </div>
                                    </td>
                                    <td style="color:var(--muted);font-size:0.85rem">
                                        📞 @p.ContactNumber
                                    </td>
                                    <td>
                                        <span style="color:var(--gold);font-weight:700">
                                            @p.RatePerKilometer.ToString("N1") ج.م
                                        </span>
                                    </td>
                                    <td>
                                        @if (p.IsActive)
                                        {
                                            <span class="status-badge status-active">✅ نشطة</span>
                                        }
                                        else
                                        {
                                            <span class="status-badge status-cancelled">🚫 معطلة</span>
                                        }
                                    </td>
                                    <td>
                                        <form asp-action="UpdateLogisticsRate" method="post"
                                              style="display:flex;gap:0.5rem;align-items:center">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@p.Id" />
                                            <input type="number" name="newRate"
                                                   class="form-control" style="width:90px;padding:0.4rem 0.6rem;font-size:0.82rem"
                                                   value="@p.RatePerKilometer" min="1" step="0.5" />
                                            <button type="submit" class="admin-btn admin-btn-unblock">
                                                💾
                                            </button>
                                        </form>
                                    </td>
                                    <td>
                                        <form asp-action="ToggleLogistics" method="post" style="display:inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@p.Id" />
                                            <button type="submit"
                                                    class="admin-btn @(p.IsActive ? "admin-btn-block" : "admin-btn-verify")"
                                                    onclick="return confirm('@(p.IsActive ? "تعطيل" : "تفعيل") شركة النقل؟')">
                                                @(p.IsActive ? "🚫 تعطيل" : "✅ تفعيل")
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>
