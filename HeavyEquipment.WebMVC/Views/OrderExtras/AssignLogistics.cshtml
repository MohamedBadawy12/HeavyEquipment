@using HeavyEquipment.Application.Features.Logistics.Dtos
@{
    ViewData["Title"] = "تعيين شركة النقل";
    Layout = "_NewLayout";
    ViewData["PageCss"] = "rental";

    var providers = ViewBag.Providers as IReadOnlyList<LogisticsProviderDto>
                    ?? new List<LogisticsProviderDto>();
}

<div class="inner-page">
    <div class="page-header">
        <div class="page-header-content">
            <div class="section-label">LOGISTICS</div>
            <div class="gold-divider"></div>
            <h1 class="section-title">شركة النقل</h1>
            <p class="page-header-desc">اختر شركة نقل لتوصيل المعدة</p>
        </div>
        <a asp-controller="RentalOrder" asp-action="Details"
           asp-route-id="@ViewBag.OrderId" class="btn-outline btn-sm">
            ← رجوع
        </a>
    </div>

    <div style="padding:2rem 4rem; max-width:700px">

        @if (!providers.Any())
        {
            <div class="empty-state">
                <div class="empty-icon">🚛</div>
                <div class="empty-title">لا توجد شركات نقل متاحة</div>
                <div class="empty-desc">تواصل مع الإدارة لإضافة شركات نقل</div>
            </div>
        }
        else
        {
            <form asp-action="AssignLogistics" asp-controller="OrderExtras" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="orderId" value="@ViewBag.OrderId" />

                <div class="form-group">
                    <label class="form-label">اختر شركة النقل *</label>

                    <div style="display:flex;flex-direction:column;gap:1rem;margin-top:0.5rem">
                        @foreach (var p in providers)
                        {
                            <label style="cursor:pointer">
                                <div style="background:var(--card);border:1px solid var(--border);
                                            padding:1.2rem 1.5rem;display:flex;align-items:center;
                                            gap:1rem;transition:border-color 0.2s"
                                     onmouseover="this.style.borderColor='rgba(212,168,67,0.4)'"
                                     onmouseout="this.style.borderColor='var(--border)'">
                                    <input type="radio" name="providerId" value="@p.Id"
                                           style="accent-color:var(--gold);width:18px;height:18px" required />
                                    <div style="flex:1">
                                        <div style="font-weight:700;margin-bottom:0.2rem">
                                            🚛 @p.CompanyName
                                        </div>
                                        <div style="color:var(--muted);font-size:0.82rem">
                                            📞 @p.ContactNumber
                                        </div>
                                    </div>
                                    <div style="text-align:left">
                                        <div style="color:var(--gold);font-weight:700;font-family:var(--font-en);font-size:1.1rem">
                                            @p.RatePerKilometer ج.م
                                        </div>
                                        <div style="color:var(--muted);font-size:0.75rem">لكل كيلومتر</div>
                                    </div>
                                </div>
                            </label>
                        }
                    </div>
                </div>

                <div style="display:flex;gap:1rem;justify-content:flex-end;margin-top:1.5rem">
                    <a asp-controller="RentalOrder" asp-action="Details"
                       asp-route-id="@ViewBag.OrderId" class="btn-outline">
                        إلغاء
                    </a>
                    <button type="submit" class="btn-primary">🚛 تعيين شركة النقل</button>
                </div>
            </form>
        }
    </div>
</div>
