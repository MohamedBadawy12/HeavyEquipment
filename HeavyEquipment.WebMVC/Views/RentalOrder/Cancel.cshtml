@{
    ViewData["Title"] = "إلغاء الطلب";
    Layout = "_NewLayout";
    ViewData["PageCss"] = "rental";
}

<div class="rental-page">
    <div style="max-width:520px; margin:4rem auto; padding:0 2rem">

        <div class="create-form-wrapper">
            <div style="text-align:center; margin-bottom:2rem">
                <div style="font-size:3rem; margin-bottom:1rem">❌</div>
                <h1 style="font-size:1.5rem; font-weight:700; margin-bottom:0.5rem">إلغاء الطلب</h1>
                <p style="color:var(--muted); font-size:0.9rem">
                    هل أنت متأكد من إلغاء هذا الطلب؟ لا يمكن التراجع عن هذا الإجراء.
                </p>
            </div>

            <form asp-action="Cancel" asp-controller="RentalOrder" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@ViewBag.OrderId" />

                <div class="form-group">
                    <label class="form-label">سبب الإلغاء *</label>
                    <textarea name="reason" class="form-control" rows="4"
                              placeholder="اذكر سبب إلغاء الطلب..." required></textarea>
                </div>

                <div class="form-actions">
                    <a asp-controller="RentalOrder"
                       asp-action="Details"
                       asp-route-id="@ViewBag.OrderId"
                       class="btn-outline">
                        رجوع
                    </a>
                    <button type="submit" class="btn-danger">تأكيد الإلغاء</button>
                </div>
            </form>
        </div>
    </div>
</div>
